# 🎀 Investor TS - Environment Configuration Example 🎀
# このファイルは、開発に必要な環境変数の「お手本」だよっ！✨
# 実際に使うときは、このファイルを `.env` にコピーしてね 💖

NODE_ENV=development

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔑 プロバイダーの認証情報（絶対に秘密だよっ！💢）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# J-Quants API (https://jquants.com/)
JQUANTS_API_KEY=your_jquants_api_key
JQUANTS_ID_TOKEN=your_optional_id_token

# EDINET API (https://disclosure2.edinet-fsa.go.jp/)
EDINET_API_KEY=your_edinet_api_key

# e-Stat API (https://www.e-stat.go.jp/)
ESTAT_APP_ID=your_estat_app_id

# OpenAI API (https://platform.openai.com/)
OPENAI_API_KEY=sk-proj-your_openai_api_key
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1

# Hugging Face (Optional)
HF_KEY=hf_your_hugging_face_token

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🐘 データベース設定 (Canonical DB)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CANONICAL_DB_URL=postgres://investor:investor@localhost:5432/investor
CANONICAL_DB_HOST=localhost
CANONICAL_DB_PORT=5432
CANONICAL_DB_NAME=investor
CANONICAL_DB_USER=investor
CANONICAL_DB_PASSWORD=investor

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🚀 実行と実験のオプション
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=INFO
VERIFY_TARGETS=jquants,kabucom,edinet,estat

# 自律型アルファ探索の入力チャンネル
UQTL_INPUT_CHANNEL=task
UQTL_NL_INPUT=
UQTL_NL_INPUT_FILE=
UQTL_EXPERIMENT_ID=exp-alpha-search-default




Polymarket_apiKey=019
Polymarket_secret=9oB
Polymarket_passphrase=7b6